# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zigzag
DB_USER=zigzag
DB_PASS=CHANGE_ME

# Session
SESSION_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX
TOKEN_EXPIRY=86400000

# Onion-only mode (set true to restrict access to .onion only)
ONION_ONLY=false

# File uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT=30

# Auto-delete (hours)
MESSAGE_TTL=24
POST_TTL=0

# Security tools (optional API keys)
VIRUSTOTAL_API_KEY=
PHISHTANK_API_KEY=
HIBP_API_KEY=
